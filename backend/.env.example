# =============================================================================
# ELLEDEN HOTEL - ENVIRONMENT VARIABLES FOR RAILWAY DEPLOYMENT
# =============================================================================
# Set these in Railway Dashboard > Variables
# =============================================================================

# Django Core Settings
SECRET_KEY=your-super-secret-key-here  # Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app

# Database (Railway provides DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# M-Pesa Daraja API (https://developer.safaricom.co.ke)
MPESA_ENVIRONMENT=production  # 'sandbox' or 'production'
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-paybill-number
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-app.up.railway.app/bookings/mpesa/callback/

# Africa's Talking SMS (https://account.africastalking.com)
AFRICASTALKING_USERNAME=your-username  # Not 'sandbox' for production
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_SENDER_ID=ELLEDEN  # Your registered sender ID

# Email Settings (Optional)
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
